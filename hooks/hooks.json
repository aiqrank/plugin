{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "timeout": 2,
            "command": "python3 $CLAUDE_PLUGIN_ROOT/scripts/hook_nudge_if_stale.py"
          },
          {
            "type": "command",
            "command": "nohup python3 $CLAUDE_PLUGIN_ROOT/scripts/hook_upload_today.py </dev/null >/dev/null 2>&1 &"
          }
        ]
      }
    ]
  }
}
