{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "timeout": 2,
            "command": "PY=$(command -v python3 || command -v python); [ -n \"$PY\" ] && \"$PY\" -u \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_nudge_if_stale.py\" || true"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "PY=$(command -v python3 || command -v python); [ -n \"$PY\" ] && \"$PY\" -u \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_upload_today.py\" || true"
          }
        ]
      }
    ]
  }
}
