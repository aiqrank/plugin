{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "timeout": 2,
            "command": "python3 -u \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_nudge_if_stale.py\""
          },
          {
            "type": "command",
            "shell": "powershell",
            "timeout": 2,
            "command": "python -u \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\hook_nudge_if_stale.py\""
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "python3 -u \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_upload_today.py\""
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "python -u \"$env:CLAUDE_PLUGIN_ROOT\\scripts\\hook_upload_today.py\""
          }
        ]
      }
    ]
  }
}
